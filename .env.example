# ============================================================================
# Constituția României - Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in your actual values.
# NEVER commit .env.local to version control.
# ============================================================================

# Neon PostgreSQL connection string
# Get yours at: https://neon.tech
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/constitutia?sslmode=require

# OpenRouter API key for AI comment moderation
# Get yours at: https://openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxx

# Arcjet API key for rate limiting and bot protection
# Get yours at: https://arcjet.com
ARCJET_KEY=ajkey_xxxxxxxxxxxx
