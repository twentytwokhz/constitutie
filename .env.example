# ============================================================================
# Constituția României - Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in your actual values.
# NEVER commit .env.local to version control.
# ============================================================================

# Neon PostgreSQL connection string
# Get yours at: https://neon.tech
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/constitutia?sslmode=require

# OpenRouter API key for AI comment moderation
# Get yours at: https://openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxx

# Arcjet API key for rate limiting and bot protection
# Get yours at: https://arcjet.com
ARCJET_KEY=ajkey_xxxxxxxxxxxx

# PostHog Analytics (optional — analytics disabled if not set)
# Sign up at: https://posthog.com (free tier: 1M events/month)
# Use EU cloud for GDPR compliance: https://eu.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Base URL for SEO (canonical URLs, sitemap, Open Graph)
# Set to your production domain
NEXT_PUBLIC_BASE_URL=https://constitutia-romaniei.ro
